# ═══════════════════════════════════════════════════════════════
# CONFIGURACIÓN DEL BOT COCINANDO RICO
# ═══════════════════════════════════════════════════════════════

# Facebook (REQUERIDO)
FB_PAGE_ID=tu_page_id_aqui
FB_ACCESS_TOKEN=tu_token_de_acceso_aqui

# Edamam API (OPCIONAL - para recetas en español)
# Obtén tus credenciales en: https://developer.edamam.com/
EDAMAM_APP_ID=tu_app_id
EDAMAM_API_KEY=tu_api_key

# Configuración de rutas
HISTORIAL_PATH=data/historial_recetas.json
ESTADO_PATH=data/estado_bot.json

# Tiempo entre publicaciones (en minutos, default: 360 = 6 horas)
TIEMPO_ENTRE_PUBLICACIONES=360
